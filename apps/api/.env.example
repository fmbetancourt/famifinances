# Copy to .env and fill real values. NEVER commit .env.
MONGODB_URI=mongodb://localhost:27017/famifinances
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
OTP_TTL=900
MAIL_FROM_ADDRESS=no-reply@famifinances.local
# Leave empty in dev to use the console mail stub. The stub logs message metadata
# only (never the OTP, per FR-027); obtain codes via a real provider or the e2e harness.
MAIL_PROVIDER_API_KEY=
