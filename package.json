{
  "name": "famifinances",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @famifinances/api test && pnpm --filter @famifinances/api test:e2e",
    "lint": "eslint ."
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "argon2",
      "mongodb-memory-server"
    ],
    "auditConfig": {
      "//": "QLT-01 baseline: apps/api-prod advisories accepted here MUST have a matching entry (rationale, reviewer, date) in docs/security-checklist.md §4.2. scripts/audit-api.mjs blocks any NEW apps/api-prod high/critical not listed here.",
      "ignoreCves": [],
      "ignoreGhsas": [
        "GHSA-xf7r-hgr6-v32p",
        "GHSA-v52c-386h-88mc",
        "GHSA-5528-5vmv-3xc2",
        "GHSA-72gw-mp4g-v24j",
        "GHSA-r5fr-rjxr-66jc",
        "GHSA-52cp-r559-cp3m"
      ]
    }
  }
}
