{
  "name": "famifinances",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @famifinances/api test && pnpm --filter @famifinances/api test:e2e",
    "lint": "eslint ."
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "argon2",
      "mongodb-memory-server"
    ],
    "auditConfig": {
      "//": "SEC-01: block-by-default. Each id ignored here MUST have a matching entry (rationale, reviewer, date) in docs/security-checklist.md.",
      "ignoreCves": [],
      "ignoreGhsas": []
    }
  }
}
